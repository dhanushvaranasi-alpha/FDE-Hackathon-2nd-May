# Copy to `.env` in this folder. Required for live LLM triage.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Google Custom Search JSON API for nearby clinics (address field only)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Optional: HTTP adapter that accepts POST JSON { query, address, locale } and returns { results: [...] }
CLINIC_SEARCH_MCP_HTTP_URL=
